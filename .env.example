# ── Observabilidad ──────────────────────────────────────────────────────────
# Monitorización en terminal (true/false)
MONITOR_ENABLED=true

# ── Defaults (heredados por todos los agentes salvo override explícito) ─────
DEFAULT_MODEL=anthropic/claude-haiku-4.5
DEFAULT_BASE_URL=https://openrouter.ai/api/v1
# Opcional: si la defines, gana sobre las API keys de proveedor inferidas.
# Si la dejas vacía, se infiere por DEFAULT_BASE_URL / nombre de modelo.
# DEFAULT_API_KEY=

# ── API keys por proveedor (usa solo las que necesites) ─────────────────────
# El backend infiere cuál usar a partir de base_url y nombre de modelo.
OPENROUTER_API_KEY=sk-or-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...
# ZAI_API_KEY=sk-...

# ── Servicios externos ──────────────────────────────────────────────────────
# Email para consultas PubMed (requerido por la API)
PUBMED_EMAIL=pipeline@paymsa.com
# Fallback de web search cuando DuckDuckGo falla
TAVILY_API_KEY=tvly-...

# ── Overrides por agente ────────────────────────────────────────────────────
# Solo declara lo que se desvía del DEFAULT_*. Campos soportados:
#   AGENT_<n>_<NOMBRE>_MODEL
#   AGENT_<n>_<NOMBRE>_BASE_URL
#   AGENT_<n>_<NOMBRE>_API_KEY
#   AGENT_<n>_<NOMBRE>_TEMPERATURE
#
# Prefijos disponibles:
#   AGENT_1_KIC        AGENT_2_REG       AGENT_3_FT       AGENT_4_CLAIMS
#   AGENT_5_ETIQUETA   AGENT_6_FORMATOS  AGENT_7_DOCS     AGENT_8_QC
#
# Ejemplos:
# AGENT_2_REG_MODEL=qwen/qwen3.6-plus-04-02
# AGENT_4_CLAIMS_MODEL=qwen/qwen3.6-plus-04-02
# AGENT_7_DOCS_BASE_URL=https://api.openai.com/v1
# AGENT_7_DOCS_API_KEY=sk-...

# Temperatura baja para minimizar alucinaciones en contexto científico/regulatorio
AGENT_1_KIC_TEMPERATURE=0.1
AGENT_2_REG_TEMPERATURE=0.1
AGENT_3_FT_TEMPERATURE=0.1
AGENT_4_CLAIMS_TEMPERATURE=0.1
AGENT_5_ETIQUETA_TEMPERATURE=0.1
AGENT_6_FORMATOS_TEMPERATURE=0.1
AGENT_7_DOCS_TEMPERATURE=0.1
AGENT_8_QC_TEMPERATURE=0.1
