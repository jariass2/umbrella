# ── Observabilidad ────────────────────────────────────────────────────
# Monitorización en terminal (true/false)
MONITOR_ENABLED=true

# Email para consultas PubMed (opcional)
PUBMED_EMAIL=pipeline@paymsa.com

# ── API keys de proveedor (opcionales, usa solo las que necesites) ───
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
ZAI_API_KEY=sk-...

# ── Configuración por defecto (aplica a todos los agentes) ───────────
DEFAULT_MODEL=glm-5-turbo
DEFAULT_BASE_URL=https://api.z.ai/api/coding/paas/v4
# Puedes poner aquí una key directa o reutilizar una de proveedor.
# Ejemplo OpenRouter: DEFAULT_API_KEY=${OPENROUTER_API_KEY}
DEFAULT_API_KEY=
DEFAULT_TEMPERATURE=0.1

# ── Overrides por agente (vacío = usa DEFAULT_*) ─────────────────────
# Campos soportados por agente:
#   *_MODEL, *_BASE_URL, *_API_KEY, *_TEMPERATURE

AGENT_1_KIC_MODEL=
AGENT_1_KIC_BASE_URL=
AGENT_1_KIC_API_KEY=
AGENT_1_KIC_TEMPERATURE=

AGENT_2_REG_MODEL=
AGENT_2_REG_BASE_URL=
AGENT_2_REG_API_KEY=
AGENT_2_REG_TEMPERATURE=

AGENT_3_FT_MODEL=
AGENT_3_FT_BASE_URL=
AGENT_3_FT_API_KEY=
AGENT_3_FT_TEMPERATURE=

AGENT_4_CLAIMS_MODEL=
AGENT_4_CLAIMS_BASE_URL=
AGENT_4_CLAIMS_API_KEY=
AGENT_4_CLAIMS_TEMPERATURE=

AGENT_5_ETIQUETA_MODEL=
AGENT_5_ETIQUETA_BASE_URL=
AGENT_5_ETIQUETA_API_KEY=
AGENT_5_ETIQUETA_TEMPERATURE=

AGENT_6_FORMATOS_MODEL=
AGENT_6_FORMATOS_BASE_URL=
AGENT_6_FORMATOS_API_KEY=
AGENT_6_FORMATOS_TEMPERATURE=

AGENT_7_DOCS_MODEL=
AGENT_7_DOCS_BASE_URL=
AGENT_7_DOCS_API_KEY=
AGENT_7_DOCS_TEMPERATURE=

AGENT_8_QC_MODEL=
AGENT_8_QC_BASE_URL=
AGENT_8_QC_API_KEY=
AGENT_8_QC_TEMPERATURE=
